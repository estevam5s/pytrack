{
  "Main guard": {
    "prefix": "pymain",
    "body": ["def main() -> None:", "    ${1:pass}", "", "", "if __name__ == \"__main__\":", "    main()"],
    "description": "Bloco principal if __name__ == '__main__'"
  },
  "Função tipada": {
    "prefix": "pyfn",
    "body": ["def ${1:nome}(${2:args}) -> ${3:None}:", "    \"\"\"${4:docstring}\"\"\"", "    ${5:pass}"],
    "description": "Função com type hints e docstring"
  },
  "Função async": {
    "prefix": "pyasync",
    "body": ["async def ${1:nome}(${2:args}) -> ${3:None}:", "    ${4:pass}"],
    "description": "Função assíncrona"
  },
  "Dataclass": {
    "prefix": "pydataclass",
    "body": ["from dataclasses import dataclass", "", "", "@dataclass", "class ${1:Nome}:", "    ${2:campo}: ${3:str}"],
    "description": "Dataclass"
  },
  "Classe": {
    "prefix": "pyclass",
    "body": ["class ${1:Nome}:", "    def __init__(self, ${2:args}) -> None:", "        ${3:self.x = x}", "", "    def ${4:metodo}(self) -> ${5:None}:", "        ${6:pass}"],
    "description": "Classe com __init__"
  },
  "Pydantic model": {
    "prefix": "pypydantic",
    "body": ["from pydantic import BaseModel, Field", "", "", "class ${1:Modelo}(BaseModel):", "    ${2:nome}: ${3:str} = Field(${4:})"],
    "description": "Modelo Pydantic"
  },
  "FastAPI app": {
    "prefix": "pyfastapi",
    "body": ["from fastapi import FastAPI", "", "app = FastAPI()", "", "", "@app.get(\"/${1:}\")", "async def ${2:handler}():", "    return {\"ok\": True}"],
    "description": "App FastAPI mínimo"
  },
  "Endpoint FastAPI": {
    "prefix": "pyroute",
    "body": ["@app.${1|get,post,put,delete|}(\"/${2:rota}\")", "async def ${3:handler}(${4:}):", "    return ${5:{}}"],
    "description": "Rota FastAPI"
  },
  "Pytest test": {
    "prefix": "pytest",
    "body": ["def test_${1:nome}() -> None:", "    # arrange", "    ${2:}", "    # act", "    resultado = ${3:}", "    # assert", "    assert resultado == ${4:esperado}"],
    "description": "Teste pytest (AAA)"
  },
  "Pytest fixture": {
    "prefix": "pyfixture",
    "body": ["import pytest", "", "", "@pytest.fixture", "def ${1:nome}():", "    ${2:yield valor}"],
    "description": "Fixture do pytest"
  },
  "Pytest parametrize": {
    "prefix": "pyparam",
    "body": ["import pytest", "", "", "@pytest.mark.parametrize(\"${1:entrada,esperado}\", [", "    (${2:1, 2}),", "])", "def test_${3:nome}(${1:entrada,esperado}):", "    assert ${4:f(entrada)} == ${5:esperado}"],
    "description": "Teste parametrizado"
  },
  "Try/except": {
    "prefix": "pytry",
    "body": ["try:", "    ${1:pass}", "except ${2:Exception} as e:", "    ${3:raise}"],
    "description": "Tratamento de exceção"
  },
  "Context manager": {
    "prefix": "pyctx",
    "body": ["from contextlib import contextmanager", "", "", "@contextmanager", "def ${1:nome}():", "    ${2:# setup}", "    try:", "        yield ${3:recurso}", "    finally:", "        ${4:# teardown}"],
    "description": "Context manager"
  },
  "Decorator": {
    "prefix": "pydecorator",
    "body": ["import functools", "", "", "def ${1:nome}(func):", "    @functools.wraps(func)", "    def wrapper(*args, **kwargs):", "        ${2:# antes}", "        result = func(*args, **kwargs)", "        ${3:# depois}", "        return result", "    return wrapper"],
    "description": "Decorator que preserva metadados"
  },
  "Logger": {
    "prefix": "pylog",
    "body": ["import logging", "", "logging.basicConfig(level=logging.INFO, format=\"%(asctime)s %(levelname)s %(message)s\")", "logger = logging.getLogger(__name__)"],
    "description": "Configuração de logging"
  },
  "Argparse CLI": {
    "prefix": "pyargparse",
    "body": ["import argparse", "", "", "def main() -> None:", "    parser = argparse.ArgumentParser(description=\"${1:descrição}\")", "    parser.add_argument(\"${2:arg}\")", "    args = parser.parse_args()", "    ${3:print(args)}", "", "", "if __name__ == \"__main__\":", "    main()"],
    "description": "CLI com argparse"
  },
  "Typer CLI": {
    "prefix": "pytyper",
    "body": ["import typer", "", "app = typer.Typer()", "", "", "@app.command()", "def ${1:comando}(${2:nome}: str):", "    typer.echo(f\"${3:Olá} {${2:nome}}\")", "", "", "if __name__ == \"__main__\":", "    app()"],
    "description": "CLI com Typer"
  },
  "Abrir arquivo": {
    "prefix": "pyopen",
    "body": ["with open(\"${1:arquivo}\", \"${2|r,w,a,rb,wb|}\", encoding=\"utf-8\") as f:", "    ${3:dados = f.read()}"],
    "description": "Abrir arquivo com with"
  },
  "Ler/escrever JSON": {
    "prefix": "pyjson",
    "body": ["import json", "", "with open(\"${1:dados.json}\", encoding=\"utf-8\") as f:", "    dados = json.load(f)", "", "with open(\"${1:dados.json}\", \"w\", encoding=\"utf-8\") as f:", "    json.dump(dados, f, ensure_ascii=False, indent=2)"],
    "description": "Ler e escrever JSON"
  },
  "List comprehension": {
    "prefix": "pylc",
    "body": ["[${1:x} for ${1:x} in ${2:iter} if ${3:cond}]"],
    "description": "List comprehension"
  },
  "Dict comprehension": {
    "prefix": "pydc",
    "body": ["{${1:k}: ${2:v} for ${1:k}, ${2:v} in ${3:itens}}"],
    "description": "Dict comprehension"
  },
  "Generator": {
    "prefix": "pygen",
    "body": ["def ${1:gen}(${2:}):", "    for ${3:item} in ${4:iter}:", "        yield ${5:item}"],
    "description": "Função geradora"
  },
  "Enum": {
    "prefix": "pyenum",
    "body": ["from enum import Enum", "", "", "class ${1:Cor}(Enum):", "    ${2:VERMELHO} = ${3:1}"],
    "description": "Enumeração"
  },
  "Type hints (3.10+)": {
    "prefix": "pytype",
    "body": ["def ${1:fn}(${2:x}: ${3:int} | None = None) -> ${4:str}:", "    ${5:pass}"],
    "description": "Type hints modernos com |"
  },
  "Requests GET": {
    "prefix": "pyrequests",
    "body": ["import requests", "", "resp = requests.get(\"${1:url}\", timeout=10)", "resp.raise_for_status()", "dados = resp.json()"],
    "description": "Requisição HTTP GET"
  },
  "httpx async": {
    "prefix": "pyhttpx",
    "body": ["import httpx", "", "", "async with httpx.AsyncClient() as client:", "    resp = await client.get(\"${1:url}\")", "    dados = resp.json()"],
    "description": "Requisição assíncrona com httpx"
  },
  "Pandas read_csv": {
    "prefix": "pypandas",
    "body": ["import pandas as pd", "", "df = pd.read_csv(\"${1:dados.csv}\")", "${2:print(df.head())}"],
    "description": "Carregar CSV com pandas"
  },
  "SQLAlchemy model": {
    "prefix": "pysqlalchemy",
    "body": ["from sqlalchemy.orm import DeclarativeBase, Mapped, mapped_column", "", "", "class Base(DeclarativeBase):", "    pass", "", "", "class ${1:User}(Base):", "    __tablename__ = \"${2:users}\"", "    id: Mapped[int] = mapped_column(primary_key=True)", "    ${3:nome}: Mapped[str]"],
    "description": "Modelo SQLAlchemy 2.0"
  },
  "asyncio.run": {
    "prefix": "pyasyncrun",
    "body": ["import asyncio", "", "", "async def main() -> None:", "    ${1:pass}", "", "", "if __name__ == \"__main__\":", "    asyncio.run(main())"],
    "description": "Executar corrotina com asyncio.run"
  },
  "Property": {
    "prefix": "pyproperty",
    "body": ["@property", "def ${1:nome}(self) -> ${2:str}:", "    return self._${1:nome}", "", "@${1:nome}.setter", "def ${1:nome}(self, valor: ${2:str}) -> None:", "    self._${1:nome} = valor"],
    "description": "Property com getter/setter"
  },
  "Abstract base class": {
    "prefix": "pyabc",
    "body": ["from abc import ABC, abstractmethod", "", "", "class ${1:Base}(ABC):", "    @abstractmethod", "    def ${2:metodo}(self) -> ${3:None}:", "        ..."],
    "description": "Classe base abstrata"
  },
  "NamedTuple": {
    "prefix": "pynamedtuple",
    "body": ["from typing import NamedTuple", "", "", "class ${1:Ponto}(NamedTuple):", "    ${2:x}: ${3:int}", "    ${4:y}: ${5:int}"],
    "description": "NamedTuple tipada"
  },
  "TypedDict": {
    "prefix": "pytypeddict",
    "body": ["from typing import TypedDict", "", "", "class ${1:Config}(TypedDict):", "    ${2:nome}: ${3:str}"],
    "description": "TypedDict"
  },
  "Protocol": {
    "prefix": "pyprotocol",
    "body": ["from typing import Protocol", "", "", "class ${1:Comparavel}(Protocol):", "    def ${2:metodo}(self) -> ${3:None}: ..."],
    "description": "Protocol (typing estrutural)"
  },
  "Match (3.10+)": {
    "prefix": "pymatch",
    "body": ["match ${1:valor}:", "    case ${2:padrao}:", "        ${3:pass}", "    case _:", "        ${4:pass}"],
    "description": "Structural pattern matching"
  },
  "Walrus": {
    "prefix": "pywalrus",
    "body": ["while (${1:linha} := ${2:input()}):", "    ${3:print(${1:linha})}"],
    "description": "Operador morsa (:=)"
  },
  "Counter": {
    "prefix": "pycounter",
    "body": ["from collections import Counter", "", "contagem = Counter(${1:iteravel})", "${2:print(contagem.most_common(3))}"],
    "description": "Contagem com Counter"
  },
  "defaultdict": {
    "prefix": "pydefaultdict",
    "body": ["from collections import defaultdict", "", "${1:grupos} = defaultdict(${2:list})"],
    "description": "defaultdict"
  },
  "lru_cache": {
    "prefix": "pylrucache",
    "body": ["from functools import lru_cache", "", "", "@lru_cache(maxsize=${1:None})", "def ${2:fn}(${3:n}: int) -> int:", "    ${4:pass}"],
    "description": "Memoization com lru_cache"
  },
  "Path (pathlib)": {
    "prefix": "pypath",
    "body": ["from pathlib import Path", "", "${1:caminho} = Path(\"${2:.}\")", "for ${3:arquivo} in ${1:caminho}.glob(\"${4:*.py}\"):", "    ${5:print(${3:arquivo})}"],
    "description": "Manipular caminhos com pathlib"
  },
  "Subprocess": {
    "prefix": "pysubprocess",
    "body": ["import subprocess", "", "resultado = subprocess.run([\"${1:comando}\"], capture_output=True, text=True, check=True)", "print(resultado.stdout)"],
    "description": "Executar comando externo"
  },
  "datetime now": {
    "prefix": "pydatetime",
    "body": ["from datetime import datetime, timezone", "", "agora = datetime.now(timezone.utc)", "${1:print(agora.isoformat())}"],
    "description": "Data/hora com timezone"
  },
  "Regex": {
    "prefix": "pyregex",
    "body": ["import re", "", "padrao = re.compile(r\"${1:\\\\d+}\")", "for m in padrao.finditer(${2:texto}):", "    ${3:print(m.group())}"],
    "description": "Expressão regular compilada"
  },
  "Threading": {
    "prefix": "pythread",
    "body": ["import threading", "", "", "def ${1:tarefa}():", "    ${2:pass}", "", "", "t = threading.Thread(target=${1:tarefa})", "t.start()", "t.join()"],
    "description": "Thread"
  },
  "ThreadPoolExecutor": {
    "prefix": "pythreadpool",
    "body": ["from concurrent.futures import ThreadPoolExecutor", "", "with ThreadPoolExecutor(max_workers=${1:5}) as ex:", "    resultados = list(ex.map(${2:funcao}, ${3:itens}))"],
    "description": "Pool de threads"
  },
  "asyncio gather": {
    "prefix": "pygather",
    "body": ["import asyncio", "", "resultados = await asyncio.gather(${1:*tarefas})"],
    "description": "Executar corrotinas em paralelo"
  },
  "Pydantic Settings": {
    "prefix": "pysettings",
    "body": ["from pydantic_settings import BaseSettings", "", "", "class Settings(BaseSettings):", "    ${1:database_url}: str", "    ", "    class Config:", "        env_file = \".env\"", "", "", "settings = Settings()"],
    "description": "Configuração por ambiente (pydantic-settings)"
  },
  "FastAPI dependency": {
    "prefix": "pydepends",
    "body": ["from fastapi import Depends", "", "", "def ${1:get_db}():", "    ${2:db = Session()}", "    try:", "        yield ${3:db}", "    finally:", "        ${4:db.close()}"],
    "description": "Dependência do FastAPI"
  },
  "FastAPI Pydantic body": {
    "prefix": "pybody",
    "body": ["from pydantic import BaseModel", "", "", "class ${1:ItemIn}(BaseModel):", "    ${2:nome}: str", "", "", "@app.post(\"/${3:itens}\")", "async def criar(item: ${1:ItemIn}):", "    return item"],
    "description": "Endpoint com corpo validado"
  },
  "NumPy array": {
    "prefix": "pynumpy",
    "body": ["import numpy as np", "", "${1:arr} = np.array([${2:1, 2, 3}])", "${3:print(${1:arr}.mean())}"],
    "description": "Array NumPy"
  },
  "Plot Matplotlib": {
    "prefix": "pyplot",
    "body": ["import matplotlib.pyplot as plt", "", "plt.plot(${1:x}, ${2:y})", "plt.xlabel(\"${3:x}\")", "plt.ylabel(\"${4:y}\")", "plt.title(\"${5:Título}\")", "plt.show()"],
    "description": "Gráfico com matplotlib"
  },
  "scikit-learn pipeline": {
    "prefix": "pysklearn",
    "body": ["from sklearn.model_selection import train_test_split", "from sklearn.pipeline import Pipeline", "", "X_train, X_test, y_train, y_test = train_test_split(${1:X}, ${2:y}, test_size=0.2, random_state=42)", "pipe = Pipeline([(\"${3:model}\", ${4:Modelo()})])", "pipe.fit(X_train, y_train)", "print(pipe.score(X_test, y_test))"],
    "description": "Pipeline scikit-learn"
  },
  "Click CLI": {
    "prefix": "pyclick",
    "body": ["import click", "", "", "@click.command()", "@click.argument(\"${1:nome}\")", "def cli(${1:nome}):", "    click.echo(f\"Olá {${1:nome}}\")", "", "", "if __name__ == \"__main__\":", "    cli()"],
    "description": "CLI com Click"
  },
  "Streamlit app": {
    "prefix": "pystreamlit",
    "body": ["import streamlit as st", "", "st.title(\"${1:Meu app}\")", "${2:valor} = st.slider(\"${3:Valor}\", 0, 100, 50)", "st.write(${2:valor})"],
    "description": "App Streamlit"
  },
  "SQLite": {
    "prefix": "pysqlite",
    "body": ["import sqlite3", "", "with sqlite3.connect(\"${1:dados.db}\") as conn:", "    cur = conn.cursor()", "    cur.execute(\"${2:CREATE TABLE IF NOT EXISTS t (id INTEGER PRIMARY KEY)}\")", "    conn.commit()"],
    "description": "Banco SQLite"
  },
  "Environment variable": {
    "prefix": "pyenv",
    "body": ["import os", "", "${1:valor} = os.environ.get(\"${2:CHAVE}\", \"${3:padrao}\")"],
    "description": "Ler variável de ambiente"
  },
  "Slots": {
    "prefix": "pyslots",
    "body": ["class ${1:Ponto}:", "    __slots__ = (\"${2:x}\", \"${3:y}\")", "", "    def __init__(self, ${2:x}, ${3:y}):", "        self.${2:x} = ${2:x}", "        self.${3:y} = ${3:y}"],
    "description": "Classe com __slots__ (economia de memória)"
  },
  "Retry decorator": {
    "prefix": "pyretry",
    "body": ["import time", "import functools", "", "", "def retry(tentativas=3, espera=1.0):", "    def deco(func):", "        @functools.wraps(func)", "        def wrapper(*args, **kwargs):", "            for i in range(tentativas):", "                try:", "                    return func(*args, **kwargs)", "                except Exception:", "                    if i == tentativas - 1:", "                        raise", "                    time.sleep(espera * (2 ** i))", "        return wrapper", "    return deco"],
    "description": "Decorator de retry com backoff"
  }
}
