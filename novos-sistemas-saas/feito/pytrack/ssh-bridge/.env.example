# Porta do bridge WebSocket
PORT=8022
# Token compartilhado (defina o MESMO valor em Configurações → SSH na IDE, se usar)
AUTH_TOKEN=troque-este-token
# Servidor SSH de destino (sua VPS)
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USER=seu_usuario
# Use SENHA ou CHAVE (chave tem prioridade):
SSH_PASSWORD=
SSH_PRIVATE_KEY_PATH=
# Opcional: lista de hosts que o cliente pode escolher (vazio = só SSH_HOST)
ALLOWED_HOSTS=
