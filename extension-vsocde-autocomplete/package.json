{
  "name": "pytrack-autocomplete",
  "publisher": "EstevamSouza",
  "displayName": "PyTrack Autocomplete — Python Pro + Projetos",
  "description": "Autocomplete profissional de Python (builtins, stdlib, padrões) e criação de 20+ tipos de projeto. Exclusivo do plano Completo da PyTrack.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "python",
    "autocomplete",
    "intellisense",
    "snippets",
    "scaffolding",
    "pytrack"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0b0b0f",
    "theme": "dark"
  },
  "license": "MIT",
  "homepage": "https://www.pytrack.com.br/extensao",
  "bugs": {
    "url": "https://www.pytrack.com.br/contato"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/estevam5s/pytrack"
  },
  "author": {
    "name": "Estevam Souza",
    "url": "https://www.pytrack.com.br"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:python"
  ],
  "scripts": {
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "package": "npm run compile -- --minify",
    "watch": "npm run compile -- --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run package"
  },
  "contributes": {
    "commands": [
      {
        "command": "pytrackAutocomplete.login",
        "title": "PyTrack Autocomplete: Entrar (verificar plano Completo)",
        "category": "PyTrack"
      },
      {
        "command": "pytrackAutocomplete.logout",
        "title": "PyTrack Autocomplete: Sair",
        "category": "PyTrack"
      },
      {
        "command": "pytrackAutocomplete.status",
        "title": "PyTrack Autocomplete: Status do plano",
        "category": "PyTrack"
      },
      {
        "command": "pytrackAutocomplete.newProject",
        "title": "PyTrack: Criar novo projeto Python…",
        "category": "PyTrack"
      }
    ],
    "configuration": {
      "title": "PyTrack Autocomplete",
      "properties": {
        "pytrackAutocomplete.apiBaseUrl": {
          "type": "string",
          "default": "https://www.pytrack.com.br",
          "description": "URL base da API da PyTrack (para verificação de plano)."
        },
        "pytrackAutocomplete.enableCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Liga/desliga o autocomplete de Python da PyTrack."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
