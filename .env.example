# ─────────────────────────────────────────────────────────────────────
# PyTrack · Exemplo de variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com os seus valores.
#   cp .env.example .env.local
# NUNCA faça commit do .env / .env.local (contêm segredos).
# Variáveis NEXT_PUBLIC_* vão para o navegador; as demais são só do servidor.
# ─────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
# URL canônica da aplicação (em produção: https://www.pytrack.com.br)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon public key)
# Chave service_role (SERVIDOR — ignora RLS; use só em webhooks/admin/jobs)
SUPABASE_SERVICE_ROLE=eyJ... (service_role secret)
# (opcional) alias aceito pelo código:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────────────────────
# Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx            # ou restricted key rk_live_xxx
# Developers → Webhooks → (seu endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs (Developers → Products → Prices)
STRIPE_PRICE_ID=price_xxx                 # Essencial mensal (R$10)
STRIPE_PRICE_ID_ANNUAL=price_xxx          # Essencial anual (R$96)
STRIPE_PRICE_ID_COMPLETO=price_xxx        # Completo mensal (R$19)
STRIPE_PRICE_ID_COMPLETO_ANNUAL=price_xxx # Completo anual (R$182)
STRIPE_PRICE_ID_SUPREMA=price_xxx         # Suprema mensal (R$46)
STRIPE_PRICE_ID_SUPREMA_ANNUAL=price_xxx  # Suprema anual (R$442)
STRIPE_PRICE_ID_VITALICIO=price_xxx       # Vitalício (pagamento único, R$697)

# Trial e indicações
STRIPE_TRIAL_DAYS=7
STRIPE_REFERRAL_COUPON=INDICACAO1MES      # id de um coupon criado na Stripe

# ── IA (OpenRouter por padrão) ───────────────────────────────────────
# openrouter.ai/keys — usada para correção de exercícios e consultor de carreira.
# (Cada usuário pode também configurar a própria IA em /configuracoes/ia.)
OPENROUTER_API_KEY=sk-or-v1-xxx
